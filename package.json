    "src",
    "docs",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carbonenginejs/format-hlsl.git"
  },
  "homepage": "https://github.com/carbonenginejs/format-hlsl#readme",
